**/__pycache__/
*.py[oc]
**/*.py[oc]
build/
**/build/
dist/
**/dist/
packages/web/src/generated/
packages/web/build/
wheels/
**/wheels/
*.egg-info
**/*.egg-info

# Your environment variables file
# This file should not be committed to version control
.env
**/.env
.DS_Store
**/.DS_Store

# Virtual environments
.venv
**/.venv

