**/.streamlit/

# Ruff configuration
.ruff_cache/
**/.ruff_cache/

# Local configuration files
*.local
**/*.local

.aider*
**/.aider*

# Ignore build archives
*.tar.gz
**/*.tar.gz

# Ignore packaged CLI binary artifact
docker-dist/cr
cr
cr.exe

# Ignore chromadb
*.chromadb

# Bun / TypeScript migration artifacts
node_modules/
bun.lock
dist-ts/
*.tsbuildinfo

