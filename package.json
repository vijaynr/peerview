{
  "name": "cr-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CR CLI monorepo (TypeScript, Bun runtime).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run packages/cli/src/cli.ts",
    "help": "bun run packages/cli/src/cli.ts help",
    "init": "bun run packages/cli/src/cli.ts init",
    "review": "bun run packages/cli/src/cli.ts review",
    "create-review": "bun run packages/cli/src/cli.ts create-review",
    "create-mr": "bun run packages/cli/src/cli.ts create-mr",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages --ext .ts",
    "lint:fix": "eslint packages --ext .ts --fix",
    "format": "prettier --write packages",
    "format:check": "prettier --check packages",
    "build:bin-dev": "bun build --compile --minify packages/cli/src/cli.ts --outfile dist/cr",
    "build:bin": "bun build --compile --minify packages/cli/src/cli.ts --outfile dist/cr && (upx dist/cr.exe || echo 'upx not found, skipping compression')",
    "build:dev": "bun run typecheck && bun run build:bin-dev",
    "build": "bun run typecheck && bun run build:bin"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "@types/bun": "latest"
  }
}
