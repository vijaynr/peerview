{
  "name": "cr-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CR CLI monorepo (TypeScript, Bun runtime).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run packages/cli/src/cli.ts",
    "help": "bun run packages/cli/src/cli.ts help",
    "init": "bun run packages/cli/src/cli.ts init",
    "review": "bun run packages/cli/src/cli.ts review",
    "create-review": "bun run packages/cli/src/cli.ts create-review",
    "create-mr": "bun run packages/cli/src/cli.ts create-mr",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint packages/ tests/",
    "lint:fix": "biome lint --write packages/ tests/",
    "format": "biome format --write packages/ tests/",
    "format:check": "biome format packages/ tests/",
    "build:bin": "bun build --compile --minify packages/cli/src/cli.ts --outfile dist/cr",
    "build:bin-compress": "bun build --compile --minify packages/cli/src/cli.ts --outfile dist/cr && (upx dist/cr.exe || echo 'upx not found, skipping compression')",
    "build": "bun run typecheck && bun run build:bin"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
